    {
      "id": "-u74Ox8EHs8HIA82rW9ci",
      "type": "text",
      "x": -1124.3386568185774,
      "y": 328.73709253714645,
      "width": 768.5194091796875,
      "height": 75,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aj",
      "roundness": null,
      "seed": 2011931145,
      "version": 218,
      "versionNonce": 1022317831,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1771954802140,
      "link": null,
      "locked": false,
      "text": "it is bad to store passwords in plaintext.\nif someone maliciously accesses the database they can read all the passwords.\nInstead you store the password hash",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "it is bad to store passwords in plaintext.\nif someone maliciously accesses the database they can read all the passwords.\nInstead you store the password hash",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "GVqOys-yfwKthRrJZQCJn",
      "type": "text",
      "x": -1053.3945707968974,
      "y": 852.353659810775,
      "width": 588.1396484375,
      "height": 75,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ao",
      "roundness": null,
      "seed": 1376801607,
      "version": 224,
      "versionNonce": 980229159,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1771954802140,
      "link": null,
      "locked": false,
      "text": "When the user inputs their password again in the future\nwe hash their input and compare it against our stored hash.\nIf they are the same -> authenticate",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "When the user inputs their password again in the future\nwe hash their input and compare it against our stored hash.\nIf they are the same -> authenticate",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "zuRVtnQkOokzpG2mh9rA2",
