    {
      "id": "E9aF495SndE7SgfupqZoC",
      "type": "text",
      "x": 1248.6517973064556,
      "y": 1852.7580176099018,
      "width": 469.15972900390625,
      "height": 350,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b13",
      "roundness": null,
      "seed": 1985436425,
      "version": 363,
      "versionNonce": 625814471,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772559097604,
      "link": null,
      "locked": false,
      "text": "Some routes should not be accessed\nby unauthorized users.\n\n\nThe backend does the real security,\nwe just want to prevent UX issues for\nreal users.\n\nWe want to redirect users away from protected\nroutes so they don't see broken pages,\nplaceholders, empty pages, app crashes etc.\n\n\nIn flutter we do this through onGenerateRoute",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Some routes should not be accessed\nby unauthorized users.\n\n\nThe backend does the real security,\nwe just want to prevent UX issues for\nreal users.\n\nWe want to redirect users away from protected\nroutes so they don't see broken pages,\nplaceholders, empty pages, app crashes etc.\n\n\nIn flutter we do this through onGenerateRoute",
      "autoResize": true,
      "lineHeight": 1.25
    },
