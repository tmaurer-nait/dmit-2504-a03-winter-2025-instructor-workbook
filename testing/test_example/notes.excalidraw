      "boundElements": [],
      "updated": 1773861840112,
      "link": null,
      "locked": false,
      "text": "Test Driven Development (TDD)",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Test Driven Development (TDD)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "ky0-fIMaQts1PQU2zAPfy",
      "type": "text",
      "x": -601.1626853950446,
      "y": 347.70505762967264,
      "width": 133.77989196777344,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "an",
      "roundness": null,
      "seed": 1545742496,
      "version": 60,
      "versionNonce": 1773374816,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773861861996,
      "link": null,
      "locked": false,
      "text": "1. write tests\n2. write code",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. write tests\n2. write code",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "jsOryNAcfEF0D7n9eDJ8H",
      "type": "text",
      "x": -679.6261565237323,
      "y": 428.21419255392914,
      "width": 580.7196044921875,
      "height": 175,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ap",
      "roundness": null,
      "seed": 1385922912,
      "version": 349,
      "versionNonce": 1368673440,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773862432851,
      "link": null,
      "locked": false,
      "text": "Cons:\n- It can be hard\n- Can limit experimentation\n- Can take more time (in that you actually write tests)\n- Requires a lot of knowledge about what you're building\n- Sometimes management hates \"wasting time\" writing tests\n- It's not very good for prototypes, or frontend",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Cons:\n- It can be hard\n- Can limit experimentation\n- Can take more time (in that you actually write tests)\n- Requires a lot of knowledge about what you're building\n- Sometimes management hates \"wasting time\" writing tests\n- It's not very good for prototypes, or frontend",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Oa_JOcguGioQIdK_DPhqF",
      "type": "text",
      "x": -686.8860508238408,
      "y": 646.3433208545837,
      "width": 601.9796142578125,
      "height": 125,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ar",
      "roundness": null,
      "seed": 750571680,
      "version": 280,
      "versionNonce": 972453024,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773862433962,
      "link": null,
      "locked": false,
      "text": "Pros:\n- it's technically faster (assuming same goal destination)\n- Works as a wireframe for your code\n- FORCES you to think about edge cases and code structure\n- Doesn't let you cheat your unit tests",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Pros:\n- it's technically faster (assuming same goal destination)\n- Works as a wireframe for your code\n- FORCES you to think about edge cases and code structure\n- Doesn't let you cheat your unit tests",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "n3Z4AjGJpIUwmCHrW4St0",
      "type": "text",
      "x": -561.4671737526768,
      "y": 1030.7102500687438,
      "width": 543.7037963867188,
      "height": 70,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "at",
