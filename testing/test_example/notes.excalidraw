      "updated": 1773860881087,
      "link": null,
      "locked": false,
      "text": "Why do testing?",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Why do testing?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "f1pqNTc-o5tYkttV0EovO",
      "type": "text",
      "x": 253.3436923556858,
      "y": 318.2994503445095,
      "width": 634.3395385742188,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a2",
      "roundness": null,
      "seed": 1797156000,
      "version": 313,
      "versionNonce": 1689876640,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773861088697,
      "link": null,
      "locked": false,
      "text": "Writing tests makes us analyze code in more depth\nTests can ensure requirements are being met\nIncrease long term stability by checking edge cases\nThey help identify bugs before they go to production\nThey run fast - way faster than I can manually check everything",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Writing tests makes us analyze code in more depth\nTests can ensure requirements are being met\nIncrease long term stability by checking edge cases\nThey help identify bugs before they go to production\nThey run fast - way faster than I can manually check everything",
      "autoResize": true,
      "lineHeight": 1.25
    },
